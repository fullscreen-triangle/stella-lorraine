\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The residue floor and its information capacity.} The diagonal floor $\beta _A$ is strictly positive and tracks $1/\lvert K_A\rvert $; no candidate is read below it; and the number of distinguishable residue values on $[\beta _A,U]$ obeys the predicted $\lceil (U-\beta _A)/\varepsilon \rceil $ bound (\Cref  {thm:floor,thm:info}).}}{11}{figure.1}\protected@file@percent }
\newlabel{fig:panel1}{{1}{11}{\textbf {The residue floor and its information capacity.} The diagonal floor $\floor _A$ is strictly positive and tracks $1/\abs {K_A}$; no candidate is read below it; and the number of distinguishable residue values on $[\floor _A,U]$ obeys the predicted $\lceil (U-\floor _A)/\eps \rceil $ bound (\Cref {thm:floor,thm:info})}{figure.1}{}}
\newlabel{fig:panel1@cref}{{[figure][1][]1}{[1][10][]11}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Strict monotonicity of the trajectory count.} The count increments by exactly one per work unit and never decrements, even when a fraction of units are ``undo'' operations restoring a prior candidate; revisited candidates yield distinct $(x,M)$ states (\Cref  {thm:monotone}, \Cref  {cor:noreturn}).}}{11}{figure.2}\protected@file@percent }
\newlabel{fig:panel2}{{2}{11}{\textbf {Strict monotonicity of the trajectory count.} The count increments by exactly one per work unit and never decrements, even when a fraction of units are ``undo'' operations restoring a prior candidate; revisited candidates yield distinct $(x,\Mcount )$ states (\Cref {thm:monotone}, \Cref {cor:noreturn})}{figure.2}{}}
\newlabel{fig:panel2@cref}{{[figure][2][]2}{[1][10][]11}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Trajectory inflation and logarithmic termination.} The closed form $T(n,d)=d(d+1)^{n-1}$ matches direct enumeration exactly; the content grows exponentially in committed units while cost grows linearly; and $n_{\mathrm  {term}}(K,d)$ is logarithmic in $K$ (\Cref  {thm:inflation,thm:termination}).}}{11}{figure.3}\protected@file@percent }
\newlabel{fig:panel3}{{3}{11}{\textbf {Trajectory inflation and logarithmic termination.} The closed form $T(n,d)=d(d+1)^{n-1}$ matches direct enumeration exactly; the content grows exponentially in committed units while cost grows linearly; and $n_{\mathrm {term}}(K,d)$ is logarithmic in $K$ (\Cref {thm:inflation,thm:termination})}{figure.3}{}}
\newlabel{fig:panel3@cref}{{[figure][3][]3}{[1][10][]11}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Runtime diagnosis: compute- vs.\ structure-limited.} A geometrically descending residue stream ($\Delta >0$) is read as compute-limited; a stream that plateaus above the floor ($\Delta =0$) as structure-limited; the classification uses the residue stream alone (\Cref  {thm:diagnosis}).}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:panel4}{{4}{11}{\textbf {Runtime diagnosis: compute- vs.\ structure-limited.} A geometrically descending residue stream ($\Delta >0$) is read as compute-limited; a stream that plateaus above the floor ($\Delta =0$) as structure-limited; the classification uses the residue stream alone (\Cref {thm:diagnosis})}{figure.4}{}}
\newlabel{fig:panel4@cref}{{[figure][4][]4}{[1][10][]11}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Residue priority and scheduler soundness.} Priority rises with descent rate and with closeness to threshold, is zero for stalled tasks and unbounded at threshold; over random task sets a stalled task never out-prioritises a converging one (\Cref  {def:priority}, \Cref  {thm:sound}).}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:panel5}{{5}{12}{\textbf {Residue priority and scheduler soundness.} Priority rises with descent rate and with closeness to threshold, is zero for stalled tasks and unbounded at threshold; over random task sets a stalled task never out-prioritises a converging one (\Cref {def:priority}, \Cref {thm:sound})}{figure.5}{}}
\newlabel{fig:panel5@cref}{{[figure][5][]5}{[1][10][]12}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Sufficiency stopping.} A sub-task released at the parent threshold $\theta $---above its own floor---leaves the global attainable residue unchanged while saving the committed cost of the additional units; the saved cost grows as the parent floor coarsens relative to the sub-task floor (\Cref  {thm:sufficiency}).}}{12}{figure.6}\protected@file@percent }
\newlabel{fig:panel6}{{6}{12}{\textbf {Sufficiency stopping.} A sub-task released at the parent threshold $\theta $---above its own floor---leaves the global attainable residue unchanged while saving the committed cost of the additional units; the saved cost grows as the parent floor coarsens relative to the sub-task floor (\Cref {thm:sufficiency})}{figure.6}{}}
\newlabel{fig:panel6@cref}{{[figure][6][]6}{[1][10][]12}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Avalanche and time-blindness of a content digest.} A single input-bit flip induces a near-half (fraction $\approx 0.5$) output bit difference, so related inputs receive maximally distant digests; and identical content at distinct times yields identical digests (\Cref  {thm:orthogonality,thm:timeblind}).}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:panel7}{{7}{12}{\textbf {Avalanche and time-blindness of a content digest.} A single input-bit flip induces a near-half (fraction $\approx 0.5$) output bit difference, so related inputs receive maximally distant digests; and identical content at distinct times yields identical digests (\Cref {thm:orthogonality,thm:timeblind})}{figure.7}{}}
\newlabel{fig:panel7@cref}{{[figure][7][]7}{[1][10][]12}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Prefix is proximity; the paired label.} The longest-common-prefix of two trajectory addresses equals their shared subtree depth; addresses extend monotonically without collision; and the paired content--time label separates recurrence, co-temporality, and refinement (\Cref  {thm:prefix,thm:queries}).}}{12}{figure.8}\protected@file@percent }
\newlabel{fig:panel8}{{8}{12}{\textbf {Prefix is proximity; the paired label.} The longest-common-prefix of two trajectory addresses equals their shared subtree depth; addresses extend monotonically without collision; and the paired content--time label separates recurrence, co-temporality, and refinement (\Cref {thm:prefix,thm:queries})}{figure.8}{}}
