\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The Residue Floor and the Information Capacity of the Residue Scale.} (\textbf  {A})~Measured diagonal floor $\beta _A$ on the logarithmic $y$-axis versus agent capacity $\lvert K_A\rvert $ on the logarithmic $x$-axis for twelve capacities $\lvert K_A\rvert \in \{2,4,8,\dots  ,4096\}$. Steelblue circles are the floor read from a bounded agent whose encoder collapses $\lvert K_A\rvert \!\cdot \!8$ candidates onto $\lvert K_A\rvert $ internal states; the crimson line is the prediction $\beta _A=1/\lvert K_A\rvert $. The measured floor coincides with $1/\lvert K_A\rvert $ to machine precision at every capacity and is strictly positive throughout, the empirical content of Theorem~\ref {thm:floor} (Residue Floor): a bounded agent cannot resolve a candidate below a strictly positive floor. (\textbf  {B})~Distribution of the residue read over all $\lvert K_A\rvert \!\cdot \!8$ candidates at capacity $\lvert K_A\rvert =256$ (steelblue bars, white edges), with the floor $\beta _A=1/256$ marked (crimson vertical line). The histogram is supported entirely at and above the floor; no candidate is read below it, confirming the no-candidate-below-floor clause of Theorem~\ref {thm:floor}. (\textbf  {C})~Number of distinguishable residue values on the logarithmic $y$-axis versus inverse precision $1/\varepsilon $ on the logarithmic $x$-axis, for floors $\beta \in \{0.1,1.0,10.0\}$ (steelblue, orange, green) over $\varepsilon \in [10^{-3},1]$. Each curve is the predicted bound $\lceil (U-\beta )/\varepsilon \rceil $ with $U=100$; the distinguishable-value count rises linearly in $1/\varepsilon $, the content of Theorem~\ref {thm:info} (Information capacity). (\textbf  {D})~Three-dimensional surface of the residue-scale information content $\log _2\!\big  ((U-\beta )/\varepsilon \big  )$ over $\log _2\lvert K_A\rvert \in [1,12]$ and $\log _{10}\varepsilon \in [-3,0]$, with $\beta =1/\lvert K_A\rvert $ and $U=100$, viridis colourmap, viewing angle elevation $24^{\circ }$ azimuth $-58^{\circ }$. The surface is strictly positive throughout and rises as precision sharpens, displaying the sizing law of Theorem~\ref {thm:info}: distinguishing residue at precision $\varepsilon $ demands the indicated bits of representational capacity.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:panel1}{{1}{4}{\textbf {The Residue Floor and the Information Capacity of the Residue Scale.} (\textbf {A})~Measured diagonal floor $\floor _A$ on the logarithmic $y$-axis versus agent capacity $\abs {K_A}$ on the logarithmic $x$-axis for twelve capacities $\abs {K_A}\in \{2,4,8,\dots ,4096\}$. Steelblue circles are the floor read from a bounded agent whose encoder collapses $\abs {K_A}\!\cdot \!8$ candidates onto $\abs {K_A}$ internal states; the crimson line is the prediction $\floor _A=1/\abs {K_A}$. The measured floor coincides with $1/\abs {K_A}$ to machine precision at every capacity and is strictly positive throughout, the empirical content of Theorem~\ref {thm:floor} (Residue Floor): a bounded agent cannot resolve a candidate below a strictly positive floor. (\textbf {B})~Distribution of the residue read over all $\abs {K_A}\!\cdot \!8$ candidates at capacity $\abs {K_A}=256$ (steelblue bars, white edges), with the floor $\floor _A=1/256$ marked (crimson vertical line). The histogram is supported entirely at and above the floor; no candidate is read below it, confirming the no-candidate-below-floor clause of Theorem~\ref {thm:floor}. (\textbf {C})~Number of distinguishable residue values on the logarithmic $y$-axis versus inverse precision $1/\eps $ on the logarithmic $x$-axis, for floors $\floor \in \{0.1,1.0,10.0\}$ (steelblue, orange, green) over $\eps \in [10^{-3},1]$. Each curve is the predicted bound $\lceil (U-\floor )/\eps \rceil $ with $U=100$; the distinguishable-value count rises linearly in $1/\eps $, the content of Theorem~\ref {thm:info} (Information capacity). (\textbf {D})~Three-dimensional surface of the residue-scale information content $\log _2\!\big ((U-\floor )/\eps \big )$ over $\log _2\abs {K_A}\in [1,12]$ and $\log _{10}\eps \in [-3,0]$, with $\floor =1/\abs {K_A}$ and $U=100$, viridis colourmap, viewing angle elevation $24^{\circ }$ azimuth $-58^{\circ }$. The surface is strictly positive throughout and rises as precision sharpens, displaying the sizing law of Theorem~\ref {thm:info}: distinguishing residue at precision $\eps $ demands the indicated bits of representational capacity}{figure.1}{}}
\newlabel{fig:panel1@cref}{{[figure][1][]1}{[1][3][]4}{}{}{}}
