\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Kuramoto Order Parameter: numerical simulation confirms the mean-field prediction $R^* = \sqrt  {1 - K_c/K}$ for $K > K_c$, with finite-size deviations scaling as $N^{-1/2}$.} (\textbf  {A}) Ensemble order parameter $R_{\mathrm  {ens}}$ versus coupling ratio $K/K_c$ for $N = 80$ Cauchy-distributed agents (red circles) against the mean-field curve $R^*(K) = \sqrt  {1 - K_c/K}$ (blue line, valid for $K > K_c$). The vertical dashed line marks $K = K_c$; simulated values track the theoretical bifurcation, rising continuously from zero at the critical point. (\textbf  {B}) Three-dimensional convergence of $R_{\mathrm  {ens}}(t)$ for four coupling ratios $K/K_c \in \{0.8, 1.2, 2.0, 3.5\}$ (coloured trajectories). Sub-critical trajectories remain near zero; super-critical trajectories climb and plateau at a value that increases monotonically with $K/K_c$. (\textbf  {C}) Phase distributions at the end of simulation for $K < K_c$ (blue bars) and $K > K_c$ (red bars) with $N = 150$. The sub-critical distribution is approximately uniform over $[0, 2\pi ]$, while the super-critical distribution concentrates in a narrow peak, confirming the symmetry-breaking synchronisation transition. (\textbf  {D}) Finite-size error $|R_{\mathrm  {sim}} - R^*|$ versus $N$ on logarithmic axes at $K = 2.5\,K_c$ (blue circles) against the $1/\sqrt  {N}$ reference (red dashed). Error decreases with $N$ at the expected rate, confirming that deviations from mean-field theory are pure finite-size fluctuations.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:kuramoto_order}{{1}{4}{\textbf {Kuramoto Order Parameter: numerical simulation confirms the mean-field prediction $R^* = \sqrt {1 - K_c/K}$ for $K > K_c$, with finite-size deviations scaling as $N^{-1/2}$.} (\textbf {A}) Ensemble order parameter $R_{\mathrm {ens}}$ versus coupling ratio $K/K_c$ for $N = 80$ Cauchy-distributed agents (red circles) against the mean-field curve $R^*(K) = \sqrt {1 - K_c/K}$ (blue line, valid for $K > K_c$). The vertical dashed line marks $K = K_c$; simulated values track the theoretical bifurcation, rising continuously from zero at the critical point. (\textbf {B}) Three-dimensional convergence of $R_{\mathrm {ens}}(t)$ for four coupling ratios $K/K_c \in \{0.8, 1.2, 2.0, 3.5\}$ (coloured trajectories). Sub-critical trajectories remain near zero; super-critical trajectories climb and plateau at a value that increases monotonically with $K/K_c$. (\textbf {C}) Phase distributions at the end of simulation for $K < K_c$ (blue bars) and $K > K_c$ (red bars) with $N = 150$. The sub-critical distribution is approximately uniform over $[0, 2\pi ]$, while the super-critical distribution concentrates in a narrow peak, confirming the symmetry-breaking synchronisation transition. (\textbf {D}) Finite-size error $|R_{\mathrm {sim}} - R^*|$ versus $N$ on logarithmic axes at $K = 2.5\,K_c$ (blue circles) against the $1/\sqrt {N}$ reference (red dashed). Error decreases with $N$ at the expected rate, confirming that deviations from mean-field theory are pure finite-size fluctuations}{figure.1}{}}
