\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Composition Inflation and Federation Admission: $T(m,D) = D(D+1)^{m-1}$ counts distinguishable joint timing trajectories in a $D$-channel federation, and agents are admitted by marginal entropy gain $\Delta H_i > c_i$.} (\textbf  {A}) $T(m,D)$ versus $m$ on a logarithmic axis for $D = 1,\ldots  ,6$ (coloured lines). Each series is linear on the log scale; the slope $(D+1)$ increases with the number of sensor channels~$D$, quantifying the combinatorial richness of multi-channel swarm coordination. (\textbf  {B}) Three-dimensional surface of $\log _{10} T(m,D)$ over $m \in [1,9]$, $D \in [1,7]$. The surface rises steeply in both directions; equal-value contours are hyperbolas in the $(m,D)$ plane, reflecting the product structure $D \cdot (D+1)^{m-1}$. (\textbf  {C}) Marginal entropy $\Delta H_i$ per agent (bar heights) against the per-agent cost threshold $c_i$ (black dashed curve) for 30 candidate agents. Blue bars (admitted) exceed their thresholds; red bars (rejected) do not. The admission rule $\Delta H_i > c_i$ selects agents that genuinely reduce federation uncertainty. (\textbf  {D}) Federation entropy $H_{\mathrm  {fed}}$ versus federation size $N$ (blue markers with shading). Growth is sub-linear ($H \propto \log N$), reflecting diminishing returns from additional agents: each new member adds less marginal information than the last.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:composition_federation}{{4}{10}{\textbf {Composition Inflation and Federation Admission: $T(m,D) = D(D+1)^{m-1}$ counts distinguishable joint timing trajectories in a $D$-channel federation, and agents are admitted by marginal entropy gain $\Delta H_i > c_i$.} (\textbf {A}) $T(m,D)$ versus $m$ on a logarithmic axis for $D = 1,\ldots ,6$ (coloured lines). Each series is linear on the log scale; the slope $(D+1)$ increases with the number of sensor channels~$D$, quantifying the combinatorial richness of multi-channel swarm coordination. (\textbf {B}) Three-dimensional surface of $\log _{10} T(m,D)$ over $m \in [1,9]$, $D \in [1,7]$. The surface rises steeply in both directions; equal-value contours are hyperbolas in the $(m,D)$ plane, reflecting the product structure $D \cdot (D+1)^{m-1}$. (\textbf {C}) Marginal entropy $\Delta H_i$ per agent (bar heights) against the per-agent cost threshold $c_i$ (black dashed curve) for 30 candidate agents. Blue bars (admitted) exceed their thresholds; red bars (rejected) do not. The admission rule $\Delta H_i > c_i$ selects agents that genuinely reduce federation uncertainty. (\textbf {D}) Federation entropy $H_{\mathrm {fed}}$ versus federation size $N$ (blue markers with shading). Growth is sub-linear ($H \propto \log N$), reflecting diminishing returns from additional agents: each new member adds less marginal information than the last}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Critical Coupling Verification: $K_c = 2\sigma _\omega /\pi $ is confirmed numerically across a fivefold range of frequency spreads, and the ratio $K_c/\sigma _\omega $ is constant at $2/\pi $.} (\textbf  {A}) $K_c$ versus $\sigma _\omega $ for $\sigma _\omega \in [0.2,\,3.0]$. Blue circles show the analytical prediction $2\sigma _\omega /\pi $; red triangles show the numerically detected transition point (first $K$ at which $R_{\mathrm  {ens}}$ exceeds three times the finite-$N$ noise floor). Both series are collinear, confirming the linear $K_c$--$\sigma _\omega $ relationship. (\textbf  {B}) Three-dimensional surface of $R_{\mathrm  {ens}}(\sigma _\omega ,\,K)$ for $\sigma _\omega \in [0.3,\,2.5]$ and $K \in [0.1,\,5.0]$. The synchronisation manifold is the ridge where $R$ transitions from near-zero to positive; its projection onto the $(\sigma _\omega ,\,K)$ plane follows the line $K = 2\sigma _\omega /\pi $. (\textbf  {C}) Ratio $K_c/\sigma _\omega $ versus $\sigma _\omega $ (blue circles) against the horizontal reference $2/\pi \approx 0.637$ (red dashed). All points lie on the reference line, demonstrating that the critical coupling scales as a universal constant times $\sigma _\omega $. (\textbf  {D}) $R_{\mathrm  {ens}}$ versus $K/K_c$ for $N \in \{20, 40, 80, 150\}$ (coloured curves). The transition sharpens with increasing $N$; for large $N$ the curve approaches a step at $K/K_c = 1$, consistent with the discontinuous bifurcation predicted in the thermodynamic limit.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:critical_coupling}{{5}{10}{\textbf {Critical Coupling Verification: $K_c = 2\sigma _\omega /\pi $ is confirmed numerically across a fivefold range of frequency spreads, and the ratio $K_c/\sigma _\omega $ is constant at $2/\pi $.} (\textbf {A}) $K_c$ versus $\sigma _\omega $ for $\sigma _\omega \in [0.2,\,3.0]$. Blue circles show the analytical prediction $2\sigma _\omega /\pi $; red triangles show the numerically detected transition point (first $K$ at which $R_{\mathrm {ens}}$ exceeds three times the finite-$N$ noise floor). Both series are collinear, confirming the linear $K_c$--$\sigma _\omega $ relationship. (\textbf {B}) Three-dimensional surface of $R_{\mathrm {ens}}(\sigma _\omega ,\,K)$ for $\sigma _\omega \in [0.3,\,2.5]$ and $K \in [0.1,\,5.0]$. The synchronisation manifold is the ridge where $R$ transitions from near-zero to positive; its projection onto the $(\sigma _\omega ,\,K)$ plane follows the line $K = 2\sigma _\omega /\pi $. (\textbf {C}) Ratio $K_c/\sigma _\omega $ versus $\sigma _\omega $ (blue circles) against the horizontal reference $2/\pi \approx 0.637$ (red dashed). All points lie on the reference line, demonstrating that the critical coupling scales as a universal constant times $\sigma _\omega $. (\textbf {D}) $R_{\mathrm {ens}}$ versus $K/K_c$ for $N \in \{20, 40, 80, 150\}$ (coloured curves). The transition sharpens with increasing $N$; for large $N$ the curve approaches a step at $K/K_c = 1$, consistent with the discontinuous bifurcation predicted in the thermodynamic limit}{figure.5}{}}
