\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Five Coordination Regimes: coordination cost is a step function of $R_{\mathrm  {ens}}$ with boundaries at $R \in \{0.30, 0.50, 0.80, 0.95\}$, and cost drops discontinuously to zero at phase lock.} (\textbf  {A}) Coordination cost versus $R_{\mathrm  {ens}}$ (blue staircase). Five distinct plateaux correspond to the turbulent ($R < 0.30$), aperture-dominated ($0.30$--$0.50$), hierarchical-cascade ($0.50$--$0.80$), coherent ($0.80$--$0.95$), and phase-locked ($R \geq 0.95$) regimes. Grey dashed lines mark the regime boundaries. (\textbf  {B}) Three-dimensional surface of $R_{\mathrm  {ens}}$ over $(K/K_c,\,\log _{10} N)$ for $N \in \{20, 50, 100, 200, 500\}$. The phase-transition ridge sharpens with increasing $N$, moving toward the mean-field bifurcation at $K/K_c = 1$. (\textbf  {C}) $R_{\mathrm  {ens}}(t)$ time series for coupling ratios $K/K_c \in \{0.5, 1.5, 3.0\}$ with the same initial condition (coloured curves). The sub-critical trajectory remains incoherent; the two super-critical trajectories converge to distinct steady-state levels, with the higher ratio converging faster. (\textbf  {D}) Histograms of $R_{\mathrm  {ens}}$ over 25 independent realisations at $K/K_c \in \{0.5, 1.5, 2.5, 4.0\}$. Distributions shift systematically to higher $R$ as $K$ increases, with the two super-critical cases concentrating at the mean-field prediction.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:five_regimes}{{2}{7}{\textbf {Five Coordination Regimes: coordination cost is a step function of $R_{\mathrm {ens}}$ with boundaries at $R \in \{0.30, 0.50, 0.80, 0.95\}$, and cost drops discontinuously to zero at phase lock.} (\textbf {A}) Coordination cost versus $R_{\mathrm {ens}}$ (blue staircase). Five distinct plateaux correspond to the turbulent ($R < 0.30$), aperture-dominated ($0.30$--$0.50$), hierarchical-cascade ($0.50$--$0.80$), coherent ($0.80$--$0.95$), and phase-locked ($R \geq 0.95$) regimes. Grey dashed lines mark the regime boundaries. (\textbf {B}) Three-dimensional surface of $R_{\mathrm {ens}}$ over $(K/K_c,\,\log _{10} N)$ for $N \in \{20, 50, 100, 200, 500\}$. The phase-transition ridge sharpens with increasing $N$, moving toward the mean-field bifurcation at $K/K_c = 1$. (\textbf {C}) $R_{\mathrm {ens}}(t)$ time series for coupling ratios $K/K_c \in \{0.5, 1.5, 3.0\}$ with the same initial condition (coloured curves). The sub-critical trajectory remains incoherent; the two super-critical trajectories converge to distinct steady-state levels, with the higher ratio converging faster. (\textbf {D}) Histograms of $R_{\mathrm {ens}}$ over 25 independent realisations at $K/K_c \in \{0.5, 1.5, 2.5, 4.0\}$. Distributions shift systematically to higher $R$ as $K$ increases, with the two super-critical cases concentrating at the mean-field prediction}{figure.2}{}}
