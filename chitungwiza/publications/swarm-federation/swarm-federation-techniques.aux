\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Zero-Overhead Phase Lock: coordination overhead vanishes discontinuously at $R_{\mathrm  {ens}} = 0.95$, and the number of consensus messages avoided scales as $N(N-1)/2$.} (\textbf  {A}) Coordination overhead versus $R_{\mathrm  {ens}}$ (blue curve) with a vertical dashed line at $R = 0.95$ (red). Overhead decreases continuously below the threshold and drops to exactly zero above it; the green shading highlights the zero-overhead region $R \geq 0.95$. (\textbf  {B}) Three-dimensional surface of per-agent overhead over $R_{\mathrm  {ens}} \in [0,\,1]$ and $\log _{10} N \in [1.3,\,2.7]$. The surface descends to a flat zero plane for $R \geq 0.95$ at all $N$, demonstrating that the overhead elimination is independent of federation size. (\textbf  {C}) Empirical CDFs of time-to-phase-lock for $K/K_c \in \{1.5, 2.0, 3.0, 5.0\}$ (coloured curves) over 40 independent realisations per condition. Higher coupling ratios produce faster lock: at $K = 5\,K_c$ the CDF rises steeply near $t = 25$, while at $K = 1.5\,K_c$ locking is slower, confirming that over-coupling accelerates convergence. (\textbf  {D}) Log--log plot of consensus messages avoided versus $N$ (blue circles) against the $N^2/2$ reference (red dashed). The saving is exactly $N(N-1)/2$ per coordination event at $R \geq 0.95$, giving quadratic scaling with federation size.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:zero_overhead}{{3}{8}{\textbf {Zero-Overhead Phase Lock: coordination overhead vanishes discontinuously at $R_{\mathrm {ens}} = 0.95$, and the number of consensus messages avoided scales as $N(N-1)/2$.} (\textbf {A}) Coordination overhead versus $R_{\mathrm {ens}}$ (blue curve) with a vertical dashed line at $R = 0.95$ (red). Overhead decreases continuously below the threshold and drops to exactly zero above it; the green shading highlights the zero-overhead region $R \geq 0.95$. (\textbf {B}) Three-dimensional surface of per-agent overhead over $R_{\mathrm {ens}} \in [0,\,1]$ and $\log _{10} N \in [1.3,\,2.7]$. The surface descends to a flat zero plane for $R \geq 0.95$ at all $N$, demonstrating that the overhead elimination is independent of federation size. (\textbf {C}) Empirical CDFs of time-to-phase-lock for $K/K_c \in \{1.5, 2.0, 3.0, 5.0\}$ (coloured curves) over 40 independent realisations per condition. Higher coupling ratios produce faster lock: at $K = 5\,K_c$ the CDF rises steeply near $t = 25$, while at $K = 1.5\,K_c$ locking is slower, confirming that over-coupling accelerates convergence. (\textbf {D}) Log--log plot of consensus messages avoided versus $N$ (blue circles) against the $N^2/2$ reference (red dashed). The saving is exactly $N(N-1)/2$ per coordination event at $R \geq 0.95$, giving quadratic scaling with federation size}{figure.3}{}}
