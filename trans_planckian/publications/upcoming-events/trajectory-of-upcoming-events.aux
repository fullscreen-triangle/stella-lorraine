\newlabel{cor:reversal-incoherent-raw}{{11.4}{25}{Incoherence Without Framework Machinery}{theorem.11.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {Genuine time reversal from $t_k$ to $t_0$ requires deleting the intervening moments $t_1,\ldots  ,t_{k-1}$ from the universe's history; deletion is not an available physical operation, and the required deletions grow linearly with reversal depth (Theorems~\ref {thm:deletion} and~\ref {thm:no-deletion}; Definition~\ref {def:distinguishability}).} (\textbf  {A})~History size at each moment $t_i$: $|\mathrm  {history}(t_i)| = i+1$, coloured by moment index (plasma scale). History grows monotonically; no physical process reduces it. The state at any moment includes the full causal record of all prior moments. (\textbf  {B})~State at $t_0$-before (history size $= 1$, dashed) versus state at $t_0$-after-reversal from depth $k$ (history size $= k+1$, solid). The two states are distinguishable by their histories and therefore distinct (Definition~\ref {def:distinguishability}). For the reversal claim to hold, the shaded extra content---$k$ moments---must be absent from the post-reversal state. (\textbf  {C})~Required deletions as a function of reversal depth $k$: deletions$(k) = k$ exactly. Any reversal of depth $k \geq 1$ requires at least one deletion; deletion is structurally unavailable (Theorem~\ref {thm:no-deletion}). (\textbf  {D})~Recurrence (solid line): history grows as the system evolves forward; at the recurrence step the configuration matches $t_0$ but the history is intact and strictly larger. Reversal claim (dashed): history would need to snap back to size $1$ at step $30$, requiring the deletion of $30$ moments. The sharp discontinuity in the dashed line marks the deletion event; no physical operation produces it.}}{26}{figure.9}\protected@file@percent }
\newlabel{fig:panel9_history_deletion}{{9}{26}{\textbf {Genuine time reversal from $t_k$ to $t_0$ requires deleting the intervening moments $t_1,\ldots ,t_{k-1}$ from the universe's history; deletion is not an available physical operation, and the required deletions grow linearly with reversal depth (Theorems~\ref {thm:deletion} and~\ref {thm:no-deletion}; Definition~\ref {def:distinguishability}).} (\textbf {A})~History size at each moment $t_i$: $|\mathrm {history}(t_i)| = i+1$, coloured by moment index (plasma scale). History grows monotonically; no physical process reduces it. The state at any moment includes the full causal record of all prior moments. (\textbf {B})~State at $t_0$-before (history size $= 1$, dashed) versus state at $t_0$-after-reversal from depth $k$ (history size $= k+1$, solid). The two states are distinguishable by their histories and therefore distinct (Definition~\ref {def:distinguishability}). For the reversal claim to hold, the shaded extra content---$k$ moments---must be absent from the post-reversal state. (\textbf {C})~Required deletions as a function of reversal depth $k$: deletions$(k) = k$ exactly. Any reversal of depth $k \geq 1$ requires at least one deletion; deletion is structurally unavailable (Theorem~\ref {thm:no-deletion}). (\textbf {D})~Recurrence (solid line): history grows as the system evolves forward; at the recurrence step the configuration matches $t_0$ but the history is intact and strictly larger. Reversal claim (dashed): history would need to snap back to size $1$ at step $30$, requiring the deletion of $30$ moments. The sharp discontinuity in the dashed line marks the deletion event; no physical operation produces it}{figure.9}{}}
